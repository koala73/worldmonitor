# ────────────────────────────────────────────────────────────────────────────────
# World Monitor — Docker Environment Variables
#
# Copy this file to .env.docker and fill in your values.
# Sensitive keys (API keys) should preferably use Docker secrets instead.
# See DOCKER.md for full documentation.
# ────────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# VITE_VARIANT=full
# LOCAL_API_PORT=46123
# LOCAL_API_MODE=docker
# LOCAL_API_CLOUD_FALLBACK=true

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# OLLAMA_API_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# ── Financial ────────────────────────────────────────────────────────────────
# FINNHUB_API_KEY=
# FRED_API_KEY=

# ── Energy ───────────────────────────────────────────────────────────────────
# EIA_API_KEY=

# ── Geospatial ───────────────────────────────────────────────────────────────
# NASA_FIRMS_API_KEY=

# ── Conflict & Humanitarian ──────────────────────────────────────────────────
# ACLED_EMAIL=
# ACLED_PASSWORD=
# ACLED_ACCESS_TOKEN=
# UCDP_ACCESS_TOKEN=

# ── Cyber Threat Intelligence ────────────────────────────────────────────────
# URLHAUS_AUTH_KEY=
# OTX_API_KEY=
# ABUSEIPDB_API_KEY=

# ── Aviation ─────────────────────────────────────────────────────────────────
# AVIATIONSTACK_API=
# ICAO_API_KEY=
# WINGBITS_API_KEY=

# ── Internet Infrastructure ─────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=

# ── Maritime ─────────────────────────────────────────────────────────────────
# AISSTREAM_API_KEY=
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
# VITE_OPENSKY_RELAY_URL=

# ── Trade ────────────────────────────────────────────────────────────────────
# WTO_API_KEY=

# ── Relay / WebSocket ────────────────────────────────────────────────────────
# WS_RELAY_URL=
# VITE_WS_RELAY_URL=

# ── Search ───────────────────────────────────────────────────────────────────
# TAVILY_API_KEYS=
# BRAVE_API_KEYS=
# SERPAPI_API_KEYS=

# ── App Auth (optional) ──────────────────────────────────────────────────────
# WORLDMONITOR_API_KEY=
