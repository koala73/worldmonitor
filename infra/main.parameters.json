{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "llmApiUrl": {
      "value": "${LLM_API_URL}"
    },
    "llmApiKey": {
      "value": "${LLM_API_KEY}"
    },
    "llmModel": {
      "value": "${LLM_MODEL}"
    },
    "azureOpenAiTenantId": {
      "value": "${AZURE_OPENAI_TENANT_ID}"
    },
    "azureOpenAiClientId": {
      "value": "${AZURE_OPENAI_CLIENT_ID}"
    },
    "azureOpenAiClientSecret": {
      "value": "${AZURE_OPENAI_CLIENT_SECRET}"
    }
  }
}
